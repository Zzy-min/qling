{
  "name": "qingling",
  "version": "0.1.0",
  "description": "轻灵 - 通用 CLI Agent，参考 learn-claude-code + Microsoft AI Agents for Beginners",
  "type": "module",
  "bin": {
    "qingling": "./dist/index.js",
    "qling": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "tui": "node dist/index.js chat",
    "repl": "node dist/index.js repl",
    "exec": "node dist/index.js run",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "dev": "tsc --watch",
    "test": "npm run build && node --test \"tests/unit/**/*.test.mjs\"",
    "test:smoke": "npm run build && node --test \"tests/smoke/**/*.test.mjs\"",
    "ci:check": "npm run build && node --test \"tests/unit/**/*.test.mjs\" && node --test \"tests/smoke/**/*.test.mjs\""
  },
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "string-width": "^8.2.0",
    "yaml": "^2.8.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/string-width": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
