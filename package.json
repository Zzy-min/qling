{
  "name": "qling",
  "version": "0.5.0",
  "description": "轻灵 Qling - 本地优先的中文 AI Agent CLI 工作台",
  "type": "module",
  "bin": {
    "qling": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "tui": "node dist/index.js chat",
    "repl": "node dist/index.js repl",
    "exec": "node dist/index.js run",
    "bootstrap": "node scripts/bootstrap.mjs",
    "daemon": "node dist/daemon.js",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "dev": "tsc --watch",
    "test": "npm run build && node --test \"tests/unit/**/*.test.mjs\"",
    "test:smoke": "npm run build && node --test \"tests/smoke/**/*.test.mjs\"",
    "ci:check": "npm run build && node --test \"tests/unit/**/*.test.mjs\" && node --test \"tests/smoke/**/*.test.mjs\""
  },
  "dependencies": {
    "axios": "^1.7.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.0",
    "playwright": "^1.59.1",
    "string-width": "^8.2.0",
    "yaml": "^2.8.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.17",
    "@types/string-width": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
