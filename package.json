{
  "name": "@qlingzzy/qling",
  "version": "1.2.2",
  "description": "轻灵 Qling - 本地优先的中文 AI Agent CLI 工作台 / Local-first Chinese AI Agent CLI workbench",
  "type": "module",
  "main": "./dist/sdk.js",
  "types": "./dist/sdk.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk.d.ts",
      "import": "./dist/sdk.js",
      "default": "./dist/sdk.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "qling": "dist/index.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "skills",
    "scripts",
    "README.md",
    "README.en.md",
    "LICENSE",
    "CHANGELOG.md",
    "package.json",
    "docs/sdk.md",
    "docs/skills.md",
    "docs/install.md",
    "docs/docker.md",
    "docs/web-routing.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "keywords": [
    "qling",
    "agent",
    "cli",
    "tui",
    "ai",
    "llm",
    "coding-agent",
    "local-first",
    "chinese",
    "mcp",
    "terminal",
    "deepseek",
    "openai-compatible"
  ],
  "author": "Zzy-min",
  "license": "MIT",
  "homepage": "https://github.com/Zzy-min/qling#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zzy-min/qling.git"
  },
  "bugs": {
    "url": "https://github.com/Zzy-min/qling/issues"
  },
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "build": "npm run clean && tsc",
    "start": "node dist/index.js",
    "tui": "node dist/index.js chat",
    "repl": "node dist/index.js repl",
    "exec": "node dist/index.js run",
    "bootstrap": "node scripts/bootstrap.mjs",
    "daemon": "node dist/daemon.js",
    "prepare": "npm run build",
    "dev": "tsc --watch",
    "test": "npm run build && node --experimental-test-module-mocks --test \"tests/unit/**/*.test.mjs\"",
    "test:smoke": "npm run build && node --test \"tests/smoke/**/*.test.mjs\"",
    "eval:smoke": "npm run build && node scripts/eval-smoke.mjs",
    "eval:recovery": "npm run build && node scripts/eval-recovery.mjs",
    "eval:anchored": "npm run build && node scripts/eval-anchored-edit.mjs",
    "eval:tasks": "npm run build && node scripts/eval-tasks.mjs",
    "eval:llm": "npm run build && node scripts/eval-llm.mjs",
    "validate:packaging": "node scripts/validate-packaging.mjs",
    "dep:layers": "node scripts/dep-layers.mjs",
    "dep:layers:json": "node scripts/dep-layers.mjs --json",
    "dep:layers:baseline": "node scripts/dep-layers.mjs --baseline",
    "dep:layers:write-baseline": "node scripts/dep-layers.mjs --write-baseline",
    "sync:scoop-bucket": "node scripts/sync-scoop-bucket.mjs",
    "build:portable-win": "node scripts/build-portable-win.mjs",
    "sync:winget-sha": "node scripts/sync-winget-sha.mjs",
    "ci:check": "npm run build && node --experimental-test-module-mocks --test \"tests/unit/**/*.test.mjs\" && node --test \"tests/smoke/**/*.test.mjs\" && node scripts/eval-smoke.mjs && node scripts/eval-tasks.mjs && node scripts/eval-anchored-edit.mjs && node scripts/validate-packaging.mjs && node scripts/dep-layers.mjs --strict"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.2.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "axios": "^1.7.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.0",
    "playwright": "^1.59.1",
    "string-width": "^8.2.0",
    "yaml": "^2.8.1",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.17",
    "@types/string-width": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
